    // Drag and Drop - Roadmap
    initDragAndDrop() {
        const container = document.getElementById('roadmapContainer');
        let draggedItem = null;
        
        container.querySelectorAll('.roadmap-drag-handle').forEach(handle => {
            handle.addEventListener('dragstart', (e) => {
                draggedItem = handle.closest('.roadmap-item');
                draggedItem.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
            });
            
            handle.addEventListener('dragend', () => {
                if (draggedItem) draggedItem.classList.remove('dragging');
                draggedItem = null;
            });
        });
        
        container.addEventListener('dragover', (e) => {
            e.preventDefault();
            const afterElement = this.getDragAfterElement(container, e.clientY);
            if (draggedItem) {
                if (afterElement) {
                    container.insertBefore(draggedItem, afterElement);
                } else {
                    container.appendChild(draggedItem);
                }
            }
        });
        
        container.addEventListener('drop', () => {
            // Update order in data
            const newOrder = Array.from(container.querySelectorAll('.roadmap-item')).map(item => item.dataset.id);
            const reordered = [];
            newOrder.forEach(id => {
                const rm = AppState.data.roadmaps.find(r => r.id === id);
                if (rm) reordered.push(rm);
            });
            AppState.data.roadmaps = reordered;
            AppState.save();
            this.renderRoadmap();
        });
    },

    getDragAfterElement(container, y) {
        const draggableElements = [...container.querySelectorAll('.roadmap-item:not(.dragging)')];
        
        return draggableElements.reduce((closest, child) => {
            const box = child.getBoundingClientRect();
            const offset = y - box.top - box.height / 2;
            
            if (offset < 0 && offset > closest.offset) {
                return { offset, element: child };
            } else {
                return closest;
            }
        }, { offset: Number.NEGATIVE_INFINITY }).element;
    },

    // Drag and Drop - Schedule
    initScheduleDragDrop() {
        const items = document.querySelectorAll('.schedule-item');
        const days = document.querySelectorAll('.schedule-items');
        
        items.forEach(item => {
            item.addEventListener('dragstart', () => {
                item.classList.add('dragging');
            });
            
            item.addEventListener('dragend', () => {
                item.classList.remove('dragging');
            });
        });
        
        days.forEach(day => {
            day.addEventListener('dragover', (e) => {
                e.preventDefault();
                day.closest('.schedule-day').classList.add('drag-over');
            });
            
            day.addEventListener('dragleave', () => {
                day.closest('.schedule-day').classList.remove('drag-over');
            });
            
            day.addEventListener('drop', (e) => {
                e.preventDefault();
                day.closest('.schedule-day').classList.remove('drag-over');
                
                const draggedItem = document.querySelector('.schedule-item.dragging');
                if (!draggedItem) return;
                
                const fromDay = draggedItem.dataset.day;
                const toDay = day.dataset.day;
                const itemId = draggedItem.dataset.id;
                
                if (fromDay === toDay) return;
                
                // Move item
                const item = AppState.data.schedule[fromDay].find(i => i.id === itemId);
                if (item) {
                    AppState.data.schedule[fromDay] = AppState.data.schedule[fromDay].filter(i => i.id !== itemId);
                    if (!AppState.data.schedule[toDay]) AppState.data.schedule[toDay] = [];
                    AppState.data.schedule[toDay].push(item);
                    AppState.save();
                    this.renderSchedule();
                }
            });
        });
    }
};

