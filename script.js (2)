                title,
                completed: false,
                target,
                current: 0,
                xp
            });
            
            AppState.save();
            UI.renderMissions();
            if (AppState.currentPage === 'roadmap') UI.renderRoadmap();
            AppState.showToast('Misi ditambahkan', 'success');
        });
    },

    // Edit mission
    editMission(roadmapId, missionId, type) {
        const roadmap = AppState.data.roadmaps.find(r => r.id === roadmapId);
        const mission = roadmap.missions[type].find(m => m.id === missionId);
        
        const content = `
            <div class="form-group">
                <label>Judul Misi                <input type="text" id="editMissionTitle" value="${mission.title}">
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Target</label>
                    <input type="number" id="editMissionTarget" value="${mission.target}" min="1">
                </div>
                <div class="form-group">
                    <label>XP</label>
                    <input type="number" id="editMissionXP" value="${mission.xp}" min="1">
                </div>
            </div>
        `;
        
        UI.openModal('Edit Misi', content, () => {
            mission.title = document.getElementById('editMissionTitle').value.trim() || mission.title;
            mission.target = parseInt(document.getElementById('editMissionTarget').value) || mission.target;
            mission.xp = parseInt(document.getElementById('editMissionXP').value) || mission.xp;
            AppState.save();
            UI.renderMissions();
            if (AppState.currentPage === 'roadmap') UI.renderRoadmap();
            if (AppState.currentPage === 'dashboard') UI.renderDashboard();
            AppState.showToast('Misi diperbarui', 'success');
        });
    },

    // Delete mission
    deleteMission(roadmapId, missionId, type) {
        if (!confirm('Yakin ingin menghapus misi ini?')) return;
        const roadmap = AppState.data.roadmaps.find(r => r.id === roadmapId);
        roadmap.missions[type] = roadmap.missions[type].filter(m => m.id !== missionId);
        AppState.save();
        UI.renderMissions();
        if (AppState.currentPage === 'roadmap') UI.renderRoadmap();
        AppState.showToast('Misi dihapus', 'info');
    },

    // Add schedule item
    addScheduleItem(day, value) {
        let text = value;
        if (!text) {
            const input = document.querySelector(`.schedule-day[data-day="${day}"] .schedule-add-input`);
            text = input.value.trim();
            if (!text) return;
            input.value = '';
        }
        
        if (!AppState.data.schedule[day]) AppState.data.schedule[day] = [];
        AppState.data.schedule[day].push({
            id: AppState.generateId(),
            text
        });
        AppState.save();
        UI.renderSchedule();
        AppState.showToast('Jadwal ditambahkan', 'success');
    },

    // Delete schedule item
    deleteScheduleItem(day, itemId) {
        AppState.data.schedule[day] = AppState.data.schedule[day].filter(i => i.id !== itemId);
        AppState.save();
        UI.renderSchedule();
    },

    // Save settings
    saveSettings() {
        const user = AppState.data.user;
        user.name = document.getElementById('settingName').value.trim() || user.name;
        user.age = parseInt(document.getElementById('settingAge').value) || user.age;
        user.dailyTarget = parseInt(document.getElementById('settingDailyTarget').value) || user.dailyTarget;
        user.weeklyTarget = parseInt(document.getElementById('settingWeeklyTarget').value) || user.weeklyTarget;
        
        AppState.save();
        AppState.applyTheme();
        UI.renderDashboard();
        AppState.showToast('Pengaturan disimpan', 'success');
    },

    // Reset all data
    resetData() {
        if (!confirm('Yakin ingin menghapus SEMUA data? Tindakan ini tidak bisa dibatalkan.')) return;
        localStorage.removeItem(CONFIG.STORAGE_KEY);
        location.reload();
    },

    // Export data
    exportData() {
        const dataStr = JSON.stringify(AppState.data, null, 2);
        const blob = new Blob([dataStr], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `life-quest-rpg-backup-${new Date().toISOString().split('T')[0]}.json`;
        a.click();
        URL.revokeObjectURL(url);
        AppState.showToast('Data diexport', 'success');
    },

    // Import data
    importData(file) {
        const reader = new FileReader();
        reader.onload = (e) => {
            try {
                const data = JSON.parse(e.target.result);
                AppState.data = data;
                AppState.migrateData();
                AppState.save();
                AppState.applyTheme();
                UI.navigateTo('dashboard');
                AppState.showToast('Data diimport berhasil', 'success');
            } catch (err) {
                AppState.showToast('File tidak valid', 'error');
            }
        };
        reader.readAsText(file);
    }
};

// ============================================
// EVENT LISTENERS
// ============================================
function initEventListeners() {
    // Navigation
    document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', (e) => {
            e.preventDefault();
            UI.navigateTo(item.dataset.page);
        });
    });

    // Mobile menu
    document.getElementById('menuToggle').addEventListener('click', () => {
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('sidebarOverlay').classList.add('active');
    });

    document.getElementById('closeSidebar').addEventListener('click', () => {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('active');
    });

    document.getElementById('sidebarOverlay').addEventListener('click', () => {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('active');
    });

    // Modal close
    document.getElementById('modalClose').addEventListener('click', UI.closeModal);
    document.querySelector('.modal-overlay').addEventListener('click', UI.closeModal);

    // FAB
    document.getElementById('fab').addEventListener('click', () => {
        switch (AppState.currentPage) {
            case 'roadmap': Actions.addRoadmap(); break;
            case 'missions': Actions.addMission(); break;
            case 'schedule': AppState.showToast('Gunakan tombol + di setiap hari', 'info'); break;
            default: AppState.showToast('Pilih halaman Roadmap atau Misi untuk menambah', 'info');
        }
    });

    // Mission tabs
    document.querySelectorAll('.mission-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.mission-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.mission-tab-content').forEach(c => c.classList.remove('active'));
            tab.classList.add('active');
            document.getElementById(`${tab.dataset.tab}Missions`).classList.add('active');
        });
    });

    // Settings
    document.getElementById('btnSaveSettings').addEventListener('click', Actions.saveSettings);

    document.querySelectorAll('.theme-option').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.theme-option').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            AppState.data.user.theme = btn.dataset.theme;
            AppState.applyTheme();
        });
    });

    document.querySelectorAll('.accent-option').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.accent-option').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            AppState.data.user.accent = btn.dataset.accent;
            AppState.applyTheme();
        });
    });

    document.getElementById('btnResetData').addEventListener('click', Actions.resetData);
    document.getElementById('btnExportData').addEventListener('click', Actions.exportData);
    document.getElementById('btnImportData').addEventListener('click', () => {
        document.getElementById('importFileInput').click();
    });
    document.getElementById('importFileInput').addEventListener('change', (e) => {
        if (e.target.files[0]) Actions.importData(e.target.files[0]);
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') UI.closeModal();
    });

    // Window resize for charts
    let resizeTimeout;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
            if (AppState.currentPage === 'stats') UI.renderStats();
        }, 250);
    });
}

// ============================================
// INITIALIZATION
// ============================================
function init() {
    AppState.load();
    initEventListeners();
    UI.navigateTo('dashboard');
    
    // Check achievements on load
    AppState.checkAchievements();
}

// Start app when DOM ready
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
} else {
    init();
}
