    // Load data dari LocalStorage
    load() {
        try {
            const saved = localStorage.getItem(CONFIG.STORAGE_KEY);
            if (saved) {
                this.data = JSON.parse(saved);
                this.migrateData();
                this.checkDailyReset();
                this.checkWeeklyReset();
            } else {
                this.data = this.getDefaultData();
                this.save();
            }
        } catch (e) {
            console.error('Error loading data:', e);
            this.data = this.getDefaultData();
        }
        this.applyTheme();
    },

    // Save data ke LocalStorage
    save() {
        try {
            localStorage.setItem(CONFIG.STORAGE_KEY, JSON.stringify(this.data));
        } catch (e) {
            console.error('Error saving data:', e);
        }
    },

    // Migrasi data jika ada perubahan struktur
    migrateData() {
        if (!this.data.user.maxStreak) this.data.user.maxStreak = this.data.user.streak;
        if (!this.data.user.dailyTarget) this.data.user.dailyTarget = 5;
        if (!this.data.user.weeklyTarget) this.data.user.weeklyTarget = 20;
        if (!this.data.user.theme) this.data.user.theme = 'dark';
        if (!this.data.user.accent) this.data.user.accent = 'indigo';
        if (!this.data.history) this.data.history = { tasksCompleted: [], xpEarned: [] };
        if (!this.data.achievements) this.data.achievements = [];
    },

    // Check dan reset harian
    checkDailyReset() {
        const today = new Date().toDateString();
        const lastActive = this.data.user.lastActiveDate;

        if (lastActive !== today) {
            const lastDate = new Date(lastActive);
            const todayDate = new Date(today);
            const diffDays = Math.floor((todayDate - lastDate) / (1000 * 60 * 60 * 24));

            if (diffDays > 1) {
                this.data.user.streak = 0;
            }

            // Reset daily missions
            this.data.roadmaps.forEach(rm => {
                rm.missions.daily.forEach(m => {
                    m.completed = false;
                    m.current = 0;
                });
            });

            this.data.user.lastActiveDate = today;
            this.save();
        }
    },

    // Check dan reset mingguan
    checkWeeklyReset() {
        const now = new Date();
        const weekStart = this.getWeekStart(now);
        const savedWeekStart = this.data.user.lastWeekStart;

        if (!savedWeekStart || weekStart !== savedWeekStart) {
            this.data.roadmaps.forEach(rm => {
                rm.missions.weekly.forEach(m => {
                    m.completed = false;
                    m.current = 0;
                });
            });
            this.data.user.lastWeekStart = weekStart;
            this.save();
        }
    },

    getWeekStart(date) {
        const d = new Date(date);
        const day = d.getDay();
        const diff = d.getDate() - day;
        return new Date(d.setDate(diff)).toDateString();
    },

    // Apply tema
    applyTheme() {
        document.documentElement.setAttribute('data-theme', this.data.user.theme);
        document.documentElement.setAttribute('data-accent', this.data.user.accent);
    },

    // XP & Level System
    addXP(amount) {
        this.data.user.xp += amount;
        const needed = this.getXPForLevel(this.data.user.level);
        
        while (this.data.user.xp >= needed) {
            this.data.user.xp -= needed;
            this.data.user.level++;
            this.showLevelUp();
        }
        
        // Record history
        const today = new Date().toDateString();
        const todayEntry = this.data.history.xpEarned.find(e => e.date === today);
        if (todayEntry) {
            todayEntry.amount += amount;
        } else {
            this.data.history.xpEarned.push({ date: today, amount });
        }
        
        this.save();
    },

    getXPForLevel(level) {
        return Math.floor(CONFIG.XP_PER_LEVEL_BASE * Math.pow(CONFIG.XP_LEVEL_MULTIPLIER, level - 1));
    },

    getXPProgress() {
        const needed = this.getXPForLevel(this.data.user.level);
        return {
            current: this.data.user.xp,
            needed: needed,
            percentage: (this.data.user.xp / needed) * 100
        };
    },

    // Streak System
    updateStreak() {
        const today = new Date().toDateString();
        if (this.data.user.lastActiveDate === today) return;
        
        const lastDate = new Date(this.data.user.lastActiveDate);
        const todayDate = new Date(today);
        const diffDays = Math.floor((todayDate - lastDate) / (1000 * 60 * 60 * 24));
        
        if (diffDays === 1) {
            this.data.user.streak++;
            if (this.data.user.streak > this.data.user.maxStreak) {
                this.data.user.maxStreak = this.data.user.streak;
            }
        } else if (diffDays > 1) {
            this.data.user.streak = 1;
        }
        
        this.data.user.lastActiveDate = today;
        this.save();
    },

    // Complete task
    completeMission(roadmapId, missionId, missionType) {
        const roadmap = this.data.roadmaps.find(r => r.id === roadmapId);
        if (!roadmap) return false;
        
        const mission = roadmap.missions[missionType].find(m => m.id === missionId);
        if (!mission || mission.completed) return false;
        
        mission.current++;
        
        if (mission.current >= mission.target) {
            mission.completed = true;
            this.data.user.totalTasksCompleted++;
            
            // Add XP
            this.addXP(mission.xp);
            
            // Show XP popup
            this.showXPPopup(mission.xp);
            
            // Record history
            const today = new Date().toDateString();
            const todayEntry = this.data.history.tasksCompleted.find(e => e.date === today);
            if (todayEntry) {
                todayEntry.count++;
            } else {
                this.data.history.tasksCompleted.push({ date: today, count: 1 });
            }
            
            // Update streak
            this.updateStreak();
            
            // Check roadmap completion
            this.checkRoadmapCompletion(roadmap);
            
            // Check achievements
            this.checkAchievements();
            
            this.save();
            return true;
        }
        
        this.save();
        return false;
    },

    // Uncheck mission
    uncheckMission(roadmapId, missionId, missionType) {
        const roadmap = this.data.roadmaps.find(r => r.id === roadmapId);
        if (!roadmap) return;
        
        const mission = roadmap.missions[missionType].find(m => m.id === missionId);
        if (!mission || !mission.completed) return;
        
        mission.completed = false;
        mission.current = 0;
        this.data.user.totalTasksCompleted = Math.max(0, this.data.user.totalTasksCompleted - 1);
        
        // Subtract XP (optional - keeping it simple, not subtracting)
        
        this.save();
    },

    // Check if roadmap is complete
    checkRoadmapCompletion(roadmap) {
        const allDailyDone = roadmap.missions.daily.every(m => m.completed);
        const allWeeklyDone = roadmap.missions.weekly.every(m => m.completed);
        
        if (allDailyDone && allWeeklyDone) {
            roadmap.completed = true;
        }
    },

    // Check achievements
    checkAchievements() {
        CONFIG.ACHIEVEMENTS.forEach(ach => {
            if (this.data.achievements.includes(ach.id)) return;
            
            let unlocked = false;
            switch (ach.type) {
                case 'streak':
                    unlocked = this.data.user.streak >= ach.requirement;
                    break;
                case 'roadmap':
                    unlocked = this.data.roadmaps.filter(r => r.completed).length >= ach.requirement;
                    break;
                case 'tasks':
                    unlocked = this.data.user.totalTasksCompleted >= ach.requirement;
                    break;
                case 'level':
                    unlocked = this.data.user.level >= ach.requirement;
                    break;
            }
            
            if (unlocked) {
                this.data.achievements.push(ach.id);
                this.showToast(`Prestasi terbuka: ${ach.title}!`, 'success');
            }
        });
        this.save();
    },

    // Get overall progress
    getOverallProgress() {
        let total = 0;
        let completed = 0;
        
        this.data.roadmaps.forEach(rm => {
            [...rm.missions.daily, ...rm.missions.weekly].forEach(m => {
                total++;
                if (m.completed) completed++;
            });
        });
        
        return { total, completed, percentage: total > 0 ? Math.round((completed / total) * 100) : 0 };
    },

    // Get today's missions
    getTodayMissions() {
        const dayName = CONFIG.DAYS_OF_WEEK[new Date().getDay()];
        const scheduleItems = this.data.schedule[dayName] || [];
        const missions = [];
        
        this.data.roadmaps.forEach(rm => {
            rm.missions.daily.forEach(m => {
                const isScheduled = scheduleItems.some(s => 
                    s.text.toLowerCase().includes(m.title.toLowerCase()) ||
                    m.title.toLowerCase().includes(s.text.toLowerCase())
                );
                if (isScheduled || !scheduleItems.length) {
                    missions.push({ ...m, roadmapId: rm.id, roadmapTitle: rm.title, type: 'daily' });
                }
            });
        });
        
        return missions;
    },

    // Get all daily missions
    getAllDailyMissions() {
        const missions = [];
        this.data.roadmaps.forEach(rm => {
            rm.missions.daily.forEach(m => {
                missions.push({ ...m, roadmapId: rm.id, roadmapTitle: rm.title, type: 'daily' });
            });
        });
        return missions;
    },

    // Get all weekly missions
    getAllWeeklyMissions() {
        const missions = [];
        this.data.roadmaps.forEach(rm => {
            rm.missions.weekly.forEach(m => {
                missions.push({ ...m, roadmapId: rm.id, roadmapTitle: rm.title, type: 'weekly' });
            });
        });
        return missions;
    },

    // Show XP popup
    showXPPopup(amount) {
        const popup = document.getElementById('xpPopup');
        const text = popup.querySelector('.xp-popup-text');
        text.textContent = `+${amount} XP`;
        
        const rect = document.activeElement.getBoundingClientRect();
        popup.style.left = `${rect.left + rect.width / 2}px`;
        popup.style.top = `${rect.top}px`;
        
        popup.classList.add('show');
        setTimeout(() => popup.classList.remove('show'), 1500);
    },

    // Show level up
    showLevelUp() {
        const overlay = document.createElement('div');
        overlay.className = 'level-up-overlay';
        overlay.innerHTML = `
            <div class="level-up-text">LEVEL UP!</div>
            <div class="level-up-sub">Level ${this.data.user.level}</div>
        `;
        document.body.appendChild(overlay);
        
        setTimeout(() => overlay.classList.add('active'), 10);
        setTimeout(() => {
            overlay.classList.remove('active');
            setTimeout(() => overlay.remove(), 300);
        }, 2500);
    },

    // Show toast
    showToast(message, type = 'info') {
        const toast = document.getElementById('toast');
        const icon = document.getElementById('toastIcon');
        const msg = document.getElementById('toastMessage');
        
        const icons = {
            success: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>',
            error: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>',
            info: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>'
        };
        
        icon.innerHTML = icons[type] || icons.info;
        icon.className = `toast-icon ${type}`;
        msg.textContent = message;
        
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3000);
    },

    // Generate unique ID
    generateId() {
        return 'id_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    }
};

